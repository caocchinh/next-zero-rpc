{
  "name": "next-zero-rpc",
  "displayName": "next-zero-rpc",
  "description": "Ctrl+Click any apiFetch() route string to jump directly to its route.ts handler",
  "version": "0.1.8",
  "publisher": "caocchinh",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caocchinh/next-zero-rpc"
  },
  "bugs": {
    "url": "https://github.com/caocchinh/next-zero-rpc/issues"
  },
  "homepage": "https://next-zero-rpc.vercel.app",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "nextjs",
    "typescript",
    "goto-definition",
    "apifetch",
    "route",
    "next-zero-rpc"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "next-zero-rpc.createRoute",
        "title": "next-zero-rpc: Create Route Handler"
      }
    ],
    "configuration": {
      "title": "next-zero-rpc",
      "properties": {
        "nextZeroRpc.apiFetchFunctionNames": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["apiFetch"],
          "description": "Function names to treat as apiFetch-style route callers. Add your own wrappers here."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "publish": "npm run build && npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.24.0",
    "typescript": "^5"
  },
  "engines_note": "No runtime dependencies — the extension is a single bundled JS file"
}
